@model eweb.Web.Models.Analytics.AnalyticsViewModel

@{
    ViewData["Title"] = "Аналітика";
}

<h2 class="mb-4">Аналітика навчання</h2>

<div class="alert alert-info">
    Загальна успішність:
    <strong>@Math.Round(Model.OverallSuccess, 1)%</strong>
</div>

<hr />

<div class="row mb-4">

    <div class="col-md-6">
        <h5 class="text-center mb-3">Успішність та час тестів</h5>

        <div style="height:350px;">
            <canvas id="dailyChart"></canvas>
        </div>
    </div>

    <div class="col-md-6">
        <h5 class="text-center mb-3">Кількість проходжень тестів</h5>

        <div style="height:350px;">
            <canvas id="attemptsChart"></canvas>
        </div>
    </div>

</div>

<hr />

@if (Model.WeakestCategories.Any())
{
    <div class="alert alert-warning">
        ⚠ Найменша успішність у темах:
        <strong>@string.Join(", ", Model.WeakestCategories)</strong>
    </div>
}

<h4 class="mb-3">Статистика по темах</h4>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Категорія</th>
            <th>Правильних тестів</th>
            <th>Кількість тестів</th>
            <th>Середній результат (%)</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var stat in Model.CategoryStats)
        {
            var weak = Model.WeakestCategories.Contains(stat.CategoryName);

            <tr class="@(weak ? "table-danger" : "")">
                <td>@stat.CategoryName</td>
                <td>@stat.CorrectAnswers</td>
                <td>@stat.TotalAnswers</td>
                <td>@Math.Round(stat.SuccessPercent, 1)%</td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Lessons"
   asp-action="Index"
   class="btn btn-outline-secondary mt-3">
    Назад
</a>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    const labels = [
    @foreach (var d in Model.DailyStats)
    {
            <text>'@d.Date.ToString("yyyy-MM-dd")',</text>
    }
    ];

    const results = [
    @foreach (var d in Model.DailyStats)
    {
            <text>@Math.Round(d.AverageResult, 1).ToString(System.Globalization.CultureInfo.InvariantCulture),</text>
    }
    ];

    const times = [
    @foreach (var d in Model.DailyStats)
    {
            <text>@Math.Round(d.AverageTimeSeconds, 1).ToString(System.Globalization.CultureInfo.InvariantCulture),</text>
    }
    ];

    const attempts = [
    @foreach (var d in Model.DailyStats)
    {
            <text>@d.Attempts,</text>
    }
    ];


    // Графік успішності та часу

    new Chart(document.getElementById('dailyChart'), {

        type: 'line',

        data: {
            labels: labels,
            datasets: [
            {
                label: 'Успішність (%)',
                data: results,
                borderWidth: 2,
                tension: 0.3,
                yAxisID: 'y'
            },
            {
                label: 'Час тесту (сек)',
                data: times,
                borderWidth: 2,
                tension: 0.3,
                yAxisID: 'y1'
            }]
        },

        options: {
            responsive: true,
            maintainAspectRatio: false,

            scales: {

                y: {
                    beginAtZero: true,
                    max: 100,
                    title: {
                        display: true,
                        text: 'Успішність (%)'
                    }
                },

                y1: {
                    position: 'right',
                    beginAtZero: true,
                    grid: {
                        drawOnChartArea: false
                    },
                    title: {
                        display: true,
                        text: 'Час (сек)'
                    }
                }

            }
        }
    });


    // Графік кількості спроб

    new Chart(document.getElementById('attemptsChart'), {

        type: 'bar',

        data: {
            labels: labels,
            datasets: [{
                label: 'Кількість спроб',
                data: attempts,
                borderWidth: 1
            }]
        },

        options: {
            responsive: true,
            maintainAspectRatio: false,

            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });

</script>