@model eweb.Web.Models.Exercises.CreateInteractiveExerciseViewModel

<h2>Create Interactive Exercise</h2>

<form asp-action="CreateFull" method="post">

    @Html.AntiForgeryToken()

    <div>
        <label>Урок</label>
        <select asp-for="LessonId">
            @foreach (var lesson in ViewBag.Lessons)
            {
                <option value="@lesson.Id"
                        selected="@(lesson.Id == Model.LessonId)">
                    @lesson.Number - @lesson.Title
                </option>
            }
        </select>
    </div>

    <div>
        <label>Назва</label>
        <input asp-for="Title" />
    </div>

    <div>
        <label>Опис</label>
        <textarea asp-for="Description"></textarea>
    </div>

    <hr />

    <h3>Завдання</h3>

    <div id="tasks-container">

        @for (int i = 0; i < Model.Tasks.Count; i++)
        {
            <div class="task-block" style="border:1px solid gray; padding:10px; margin-bottom:10px;">

                <input type="hidden" name="Tasks.Index" value="@i" />

                <h4>Завдання @(i + 1)</h4>

                <div>
                    <label>Тип</label>
                    <select name="Tasks[@i].Type" class="task-type-select">
                        <option value="1" selected="@(Model.Tasks[i].Type == eweb.Domain.Entities.Exercises.ExerciseType.MultipleChoice)">
                            Вибір відповіді
                        </option>
                        <option value="2" selected="@(Model.Tasks[i].Type == eweb.Domain.Entities.Exercises.ExerciseType.Reorder)">
                            Встановити порядок
                        </option>
                        <option value="3" selected="@(Model.Tasks[i].Type == eweb.Domain.Entities.Exercises.ExerciseType.MatchPairs)">
                            Зіставити пари
                        </option>
                        <option value="4" selected="@(Model.Tasks[i].Type == eweb.Domain.Entities.Exercises.ExerciseType.FillGaps)">
                            Заповнити пропуск
                        </option>
                    </select>
                </div>

                <div>
                    <label>Питання</label>
                    <input name="Tasks[@i].QuestionText" value="@Model.Tasks[i].QuestionText" />
                </div>

                <div>
                    <label>Кількість зірок</label>
                    <input name="Tasks[@i].StarsReward"
                           type="number"
                           min="1"
                           max="2"
                           value="@Model.Tasks[i].StarsReward" />
                </div>

                <hr />

                <div class="multiple-choice-block">

                    <h5>Вибір відповіді</h5>

                    <input name="Tasks[@i].Option1" value="@Model.Tasks[i].Option1" />
                    <input type="checkbox"
                           name="Tasks[@i].IsOption1Correct"
                           value="true"
                           @(Model.Tasks[i].IsOption1Correct ? "checked" : "") />
                    <input type="hidden"
                           name="Tasks[@i].IsOption1Correct"
                           value="false" /> Правильна

                    <br />

                    <input name="Tasks[@i].Option2" value="@Model.Tasks[i].Option2" />
                    <input type="checkbox"
                           name="Tasks[@i].IsOption2Correct"
                           value="true"
                           @(Model.Tasks[i].IsOption2Correct ? "checked" : "") />
                    <input type="hidden"
                           name="Tasks[@i].IsOption2Correct"
                           value="false" /> Правильна

                    <br />

                    <input name="Tasks[@i].Option3" value="@Model.Tasks[i].Option3" />
                    <input type="checkbox"
                           name="Tasks[@i].IsOption3Correct"
                           value="true"
                           @(Model.Tasks[i].IsOption3Correct ? "checked" : "") />
                    <input type="hidden"
                           name="Tasks[@i].IsOption3Correct"
                           value="false" /> Правильна

                    <br />

                    <input name="Tasks[@i].Option4" value="@Model.Tasks[i].Option4" />
                    <input type="checkbox"
                           name="Tasks[@i].IsOption4Correct"
                           value="true"
                           @(Model.Tasks[i].IsOption4Correct ? "checked" : "") />
                    <input type="hidden"
                           name="Tasks[@i].IsOption4Correct"
                           value="false" /> Правильна

                </div>
                <div class="reorder-block" style="display:none;">

                    <h5>Будь ласка, запишіть у правильному порядку</h5>

                    <div style="display:flex; gap:10px;">
                        <input name="Tasks[@i].ReorderItem1" placeholder="Слово 1" />
                        <input name="Tasks[@i].ReorderItem2" placeholder="Слово 2" />
                        <input name="Tasks[@i].ReorderItem3" placeholder="Слово 3" />
                        <input name="Tasks[@i].ReorderItem4" placeholder="Слово 4" />
                    </div>
                    <div>
                        <label>Правильний порядок (напр. 2,4,1,3)</label>
                        <input name="Tasks[@i].CorrectOrder"
                               value="@Model.Tasks[i].CorrectOrder"
                               placeholder="1,2,3,4" />
                    </div>

                </div>
                <div class="matchpairs-block" style="display:none;">

                    <h5>Будь ласка, запишіть пари у правильному порядку</h5>

                    <div style="display:flex; gap:40px;">

                        <div>
                            <input name="Tasks[@i].Left1" placeholder="Лівий 1" /><br />
                            <input name="Tasks[@i].Left2" placeholder="Лівий 2" /><br />
                            <input name="Tasks[@i].Left3" placeholder="Лівий 3" /><br />
                            <input name="Tasks[@i].Left4" placeholder="Лівий 4" />
                        </div>

                        <div>
                            <input name="Tasks[@i].Right1" placeholder="Правий 1" /><br />
                            <input name="Tasks[@i].Right2" placeholder="Правий 2" /><br />
                            <input name="Tasks[@i].Right3" placeholder="Правий 3" /><br />
                            <input name="Tasks[@i].Right4" placeholder="Правий 4" />
                        </div>

                    </div>

                </div>
                <div class="fillgaps-block" style="display:none;">
                    <h5>Заповніть пропуск (одна правильна відповідь)</h5>

                    <input name="Tasks[@i].GapOption1" placeholder="Варіант 1" /><br />
                    <input name="Tasks[@i].GapOption2" placeholder="Варіант 2" /><br />
                    <input name="Tasks[@i].GapOption3" placeholder="Варіант 3" /><br />
                    <input name="Tasks[@i].GapOption4" placeholder="Варіант 4" /><br />

                    <p>Оберіть правильний варіант:</p>
                    <select name="Tasks[@i].CorrectOptionIndex">
                        <option value="1">1</option>
                        <option value="2">2</option>
                        <option value="3">3</option>
                        <option value="4">4</option>
                    </select>
                </div>

                <button type="button" class="remove-task-btn">Видалити</button>

            </div>
        }

    </div>

    <button type="button" id="add-task-btn">+ Додати завдання</button>

    <br /><br />
    <button type="submit">Зберегти</button>

</form>

<!-- ================= TEMPLATE ================= -->

<script type="text/template" id="task-template">
    <div class="task-block" style="border:1px solid gray; padding:10px; margin-bottom:10px;">

        <input type="hidden" name="Tasks.Index" value="__index__" />

        <h4>Завдання __number__</h4>

        <div>
            <label>Тип</label>
            <select name="Tasks[__index__].Type" class="task-type-select">
                <option value="1">Вибір відповіді</option>
                <option value="2">Встановити порядок</option>
                <option value="3">Зіставити пари</option>
                <option value="4">Заповнити пропуск</option>
            </select>
        </div>

        <div>
            <label>Питання</label>
            <input name="Tasks[__index__].QuestionText" />
        </div>

        <div>
            <label>Кількість зірок</label>
            <input name="Tasks[__index__].StarsReward"
                   type="number"
                   min="1"
                   max="2"
                   value="1" />
        </div>

        <hr />

        <div class="multiple-choice-block">
            <h5>Вибір відповіді</h5>

            <input name="Tasks[__index__].Option1" placeholder="Варіант 1" />
            <input type="checkbox" name="Tasks[__index__].IsOption1Correct" value="true" />
            <input type="hidden" name="Tasks[__index__].IsOption1Correct" value="false" /> Правильна
            <br />

            <input name="Tasks[__index__].Option2" placeholder="Варіант 2" />
            <input type="checkbox" name="Tasks[__index__].IsOption2Correct" value="true" />
            <input type="hidden" name="Tasks[__index__].IsOption2Correct" value="false" /> Правильна
            <br />

            <input name="Tasks[__index__].Option3" placeholder="Варіант 3" />
            <input type="checkbox" name="Tasks[__index__].IsOption3Correct" value="true" />
            <input type="hidden" name="Tasks[__index__].IsOption3Correct" value="false" /> Правильна
            <br />

            <input name="Tasks[__index__].Option4" placeholder="Варіант 4" />
            <input type="checkbox" name="Tasks[__index__].IsOption4Correct" value="true" />
            <input type="hidden" name="Tasks[__index__].IsOption4Correct" value="false" /> Правильна
        </div>

        <div class="reorder-block" style="display:none;">
            <h5>Запишіть у правильному порядку</h5>
            <div style="display:flex; gap:10px;">
                <input name="Tasks[__index__].ReorderItem1" placeholder="Слово 1" />
                <input name="Tasks[__index__].ReorderItem2" placeholder="Слово 2" />
                <input name="Tasks[__index__].ReorderItem3" placeholder="Слово 3" />
                <input name="Tasks[__index__].ReorderItem4" placeholder="Слово 4" />
            </div>
            <div>
                <label>Правильний порядок (напр. 2,4,1,3)</label>
                <input name="Tasks[__index__].CorrectOrder" placeholder="1,2,3,4" />
            </div>
        </div>

        <div class="matchpairs-block" style="display:none;">
            <h5>Запишіть пари</h5>
            <div style="display:flex; gap:40px;">
                <div>
                    <input name="Tasks[__index__].Left1" placeholder="Лівий 1" /><br />
                    <input name="Tasks[__index__].Left2" placeholder="Лівий 2" /><br />
                    <input name="Tasks[__index__].Left3" placeholder="Лівий 3" /><br />
                    <input name="Tasks[__index__].Left4" placeholder="Лівий 4" />
                </div>
                <div>
                    <input name="Tasks[__index__].Right1" placeholder="Правий 1" /><br />
                    <input name="Tasks[__index__].Right2" placeholder="Правий 2" /><br />
                    <input name="Tasks[__index__].Right3" placeholder="Правий 3" /><br />
                    <input name="Tasks[__index__].Right4" placeholder="Правий 4" />
                </div>
            </div>
        </div>

        <div class="fillgaps-block" style="display:none;">
            <h5>Заповніть пропуск</h5>
            <input name="Tasks[__index__].GapOption1" placeholder="Варіант 1" /><br />
            <input name="Tasks[__index__].GapOption2" placeholder="Варіант 2" /><br />
            <input name="Tasks[__index__].GapOption3" placeholder="Варіант 3" /><br />
            <input name="Tasks[__index__].GapOption4" placeholder="Варіант 4" />
            <p>Оберіть правильний варіант:</p>
            <select name="Tasks[__index__].CorrectOptionIndex">
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
            </select>
        </div>

        <hr />
        <button type="button" class="remove-task-btn">Видалити</button>

    </div>
</script>

<!-- ================= SCRIPT ================= -->

<script>
    let taskIndex = @Model.Tasks.Count;

    document.getElementById("add-task-btn").addEventListener("click", function () {

        const container = document.getElementById("tasks-container");

        if (container.children.length >= 5) {
            alert("Maximum 5 tasks allowed.");
            return;
        }

        const template = document.getElementById("task-template").innerHTML;

        const newTask = template
            .replaceAll("__index__", taskIndex)
            .replaceAll("__number__", taskIndex + 1);

        container.insertAdjacentHTML("beforeend", newTask);

        taskIndex++;
    });

    document.addEventListener("click", function (e) {
        if (e.target.classList.contains("remove-task-btn")) {
            e.target.closest(".task-block").remove();
        }
    });
</script>

<script>
    document.addEventListener("change", function(e) {

        if (!e.target.classList.contains("task-type-select"))
            return;

        const select = e.target;
        const taskBlock = select.closest(".task-block");

        const mc = taskBlock.querySelector(".multiple-choice-block");
        const reorder = taskBlock.querySelector(".reorder-block");
        const match = taskBlock.querySelector(".matchpairs-block");
        const fill = taskBlock.querySelector(".fillgaps-block");

        mc.style.display = "none";
        reorder.style.display = "none";
        match.style.display = "none";
        fill.style.display = "none";

        const value = parseInt(select.value);

        if (value === 1) mc.style.display = "block";
        if (value === 2) reorder.style.display = "block";
        if (value === 3) match.style.display = "block";
        if (value === 4) fill.style.display = "block";
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function() {

        document.querySelectorAll(".task-type-select").forEach(select => {
            select.dispatchEvent(new Event("change"));
        });

    });
</script>