@using eweb.Domain.Constants
@model eweb.Web.Models.Lessons.LessonDetailsViewModel

@{
    ViewData["Title"] = "Урок";
    bool isAdmin = User.IsInRole(RoleNames.Admin);
}

<h2>Урок №@Model.Number</h2>

<hr />

<div class="card mb-4">
    <div class="card-body">

        <h4>@Model.Title</h4>

        <p class="text-muted">
            @Model.Description
        </p>

        <hr />

        <div>
            @Model.Content
        </div>

        @if (isAdmin)
        {
            <hr />

            <p>
                <strong>Статус:</strong>
                @if (Model.IsPublished)
                {
                    <span class="text-success">Опубліковано</span>
                }
                else
                {
                    <span class="text-danger">Чернетка</span>
                }
            </p>
        }

        <p>
            <strong>Створено:</strong>
            @Model.CreatedAt
        </p>

    </div>
</div>

<hr />

@if (Model.Questions.Any())
{
    <h4>Тест</h4>

    @if (!isAdmin)
    {
        <p>
            <strong>Спроби:</strong> @Model.AttemptsCount / 10
        </p>
    }

    @if (Model.AttemptsExceeded && !isAdmin)
    {
        <div class="alert alert-danger">
            Ви використали всі 10 спроб тесту.
        </div>
    }
    else
    {
        <form method="post">

            <input type="hidden" asp-for="LessonId" />

            @for (int i = 0; i < Model.Questions.Count; i++)
            {
                <div class="card mb-3">
                    <div class="card-body">

                        <input type="hidden"
                               asp-for="Questions[i].QuestionId" />

                        <h6>
                            @(i + 1). @Model.Questions[i].QuestionText
                        </h6>

                        @for (int j = 0; j < Model.Questions[i].Answers.Count; j++)
                        {
                            var answer = Model.Questions[i].Answers[j];

                            <div class="form-check">

                                <input type="hidden"
                                       asp-for="Questions[i].Answers[j].AnswerId" />

                                <input class="form-check-input"
                                       asp-for="Questions[i].Answers[j].IsSelected"
                                       type="checkbox" />

                                <label class="form-check-label">

                                    @answer.Text

                                    @if (isAdmin || Model.ShowCorrectAnswers)
                                    {
                                        if (answer.IsSelected)
                                        {
                                            <span class="text-success">
                                                ✔
                                            </span>
                                        }
                                    }

                                </label>

                            </div>
                        }

                    </div>
                </div>
            }

            @if (Model.AttemptsExceeded)
            {
                <button type="submit" disabled style="opacity:0.5; cursor:not-allowed;">
                    Спроби вичерпано
                </button>
            }
            else
            {
                <button type="submit">Відправити</button>
            }

        </form>
    }

    @if (Model.ResultPercent != null)
    {
        <div class="alert alert-info mt-4">
            Ваш результат:
            <strong>@Model.ResultPercent %</strong>
        </div>
    }
}
else
{
    <div class="alert alert-secondary">
        До цього уроку ще немає тесту.
    </div>
}

@if (Model.ShowCorrectAnswersModal)
{
    <button type="button"
            onclick="document.getElementById('correctAnswersModal').style.display='flex'"
            style="margin-top:1rem;">
        Переглянути правильні відповіді
    </button>

    <div id="correctAnswersModal"
         style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center;">

        <div style="background:#fff; padding:2rem; border-radius:8px; max-width:600px; width:100%; max-height:80vh; overflow-y:auto;">

            <h4>Правильні відповіді</h4>

            @foreach (var q in Model.Questions)
            {
                <p><strong>@q.QuestionText</strong></p>

                <ul>
                    @foreach (var a in q.Answers.Where(a => a.IsSelected))
                    {
                        <li>@a.Text</li>
                    }
                </ul>
            }

            <button type="button"
                    onclick="document.getElementById('correctAnswersModal').style.display='none'">
                Закрити
            </button>

        </div>
    </div>
}

<hr />

<a asp-action="Index" class="btn btn-outline-secondary">
    Назад до списку уроків
</a>