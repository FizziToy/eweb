@model eweb.Web.Models.Questions.CreateQuestionViewModel

@{
    ViewData["Title"] = "Create Question";
}

<h2>Додати питання</h2>

<form asp-action="CreateQuestion" method="post">
    <input type="hidden" asp-for="LessonId" />

    <div class="form-group">
        <label asp-for="QuestionText"></label>
        <input asp-for="QuestionText" class="form-control" />
        <span asp-validation-for="QuestionText" class="text-danger"></span>
    </div>

    <h4>Варіанти відповідей</h4>

    @for (int i = 0; i < Model.Answers.Count; i++)
    {
        <div class="form-group">
            <input asp-for="Answers[i].Text" class="form-control" placeholder="Текст відповіді" />
            <input asp-for="Answers[i].IsCorrect" type="checkbox" />
            <label>Правильна</label>
        </div>
    }
    <button type="submit" name="addAnswer" value="true" class="btn btn-secondary">
        + Додати варіант
    </button>

    <button type="submit" class="btn btn-primary mt-2">Зберегти</button>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}